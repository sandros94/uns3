{
  "name": "uns3",
  "version": "0.0.7",
  "description": "Runtime agnostic S3 client.",
  "license": "MIT",
  "author": {
    "name": "Sandro Circi",
    "email": "sandro.circi@digitoolmedia.com"
  },
  "repository": "sandros94/uns3",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    "./core": "./dist/core.mjs",
    "./utils": "./dist/utils.mjs",
    ".": {
      "types": "./dist/index.d.mts",
      "core": "./dist/core.mjs",
      "utils": "./dist/utils.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "postinstall": "pnpm simple-git-hooks",
    "build": "obuild",
    "dev:prepare": "obuild --stub",
    "lint": "oxlint . && oxfmt --check .",
    "fmt": "automd && oxlint --fix . && oxfmt .",
    "prepack": "pnpm build",
    "release": "pnpm test && pnpm prepack && changelogen --release --push",
    "test": "vitest run --slowTestThreshold=1000",
    "test:coverage": "vitest run --coverage --slowTestThreshold=1000",
    "typecheck": "tsgo --noEmit",
    "bench": "vitest bench --run"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@typescript/native-preview": "7.0.0-dev.20260307.1",
    "@vitest/coverage-v8": "^4.0.18",
    "automd": "^0.4.3",
    "changelogen": "^0.6.2",
    "nano-staged": "^0.9.0",
    "obuild": "^0.4.20",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "resolutions": {
    "uns3": "link:."
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "*.{js,ts,mjs,cjs,json,yml,md}": [
      "pnpm run fmt"
    ]
  },
  "engines": {
    "node": "^22.12 || >=24"
  },
  "packageManager": "pnpm@10.32.0"
}
